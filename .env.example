# GLPI REST API — Credenciais obrigatórias
# Copie este arquivo para .env e preencha com suas credenciais reais.

# URL base da API REST do GLPI (já deve incluir /apirest.php)
GLPI_URL=http://seu-glpi.empresa.com/apirest.php

# User-Token do usuário de integração (gerado em: Perfil → API → User token)
GLPI_USER_TOKEN=seu_user_token_aqui

# App-Token da aplicação cadastrada no GLPI (gerado em: Config → Geral → API)
GLPI_APP_TOKEN=seu_app_token_aqui

# IDs das categorias de contratação no GLPI (separados por vírgula)
# Para descobrir o ID: abra um chamado da categoria no GLPI e veja o número na URL
CATEGORIA_CONTRATACAO_IDS=152,153

# ID da categoria que exige envio de equipamento ao novo funcionário (número único).
# Chamados nessa categoria recebem controle de "Termo de responsabilidade" na planilha.
# O script cria a tarefa automaticamente no GLPI se ela ainda não existir.
# Deixe em branco para desativar (todos ficam como "Sem equipamento").
CATEGORIA_CONTRATACAO_ID_WITH_ASSETS=

# Intervalo entre varreduras do GLPI Sync, em segundos (padrão: 300 = 5 minutos)
POLLING_INTERVAL=300

# Porta do servidor web (padrão: 8000)
# WEB_PORT=8000
